        0
      ],
      "id": "364ae1b3-e6e8-4561-8128-1cd3b31aa8b1",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of items) {\n  const dataArray = Array.isArray(item.json) ? item.json : [item.json];\n\n  for (const place of dataArray) {\n    if (!place || !place.title) continue;\n\n    results.push({\n      json: {\n        company_name: place.title || \"\",\n        city: place.city || \"\",\n        address: place.address || \"\",\n        phone: place.phone || place.phoneUnformatted || \"\",\n        website: place.website || \"\",\n        category: place.categoryName || \"\",\n        rating: place.totalScore || \"\",\n        reviews_count: place.reviewsCount || \"\"\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: {} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "5cd685b2-e3f5-4a45-900e-760c380b4c10",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a B2B lead qualification assistant for YOUR_COMPANY_NAME — a company selling YOUR_PRODUCT_OR_SERVICE to YOUR_TARGET_INDUSTRY companies.\n\nCompany data:\nName: {{ $json.company_name }}\nCity: {{ $json.city }}\nCategory: {{ $json.category }}\nRating: {{ $json.rating }}\nWebsite: {{ $json.website }}\n\nReturn ONLY valid JSON with exactly these 3 fields:\n{\n  \"fit_score\": <number 1-5>,\n  \"fit_reason\": \"<one sentence explaining the score>\",\n  \"outreach_message\": \"<one sentence to open a conversation with the lead>\"\n}\n\nNo markdown. No explanation. JSON only.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        864,
        0
      ],
