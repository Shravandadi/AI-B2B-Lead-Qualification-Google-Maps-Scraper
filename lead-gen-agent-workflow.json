        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"searchStringsArray\": [\"YOUR_SEARCH_QUERY\"],\n  \"maxCrawledPlacesPerSearch\": 25,\n  \"language\": \"YOUR_LANGUAGE_CODE\",\n  \"countryCode\": \"YOUR_COUNTRY_CODE\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
