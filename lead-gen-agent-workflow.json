      "name": "Mistral Cloud Chat Model",
      "credentials": {
        "mistralCloudApi": {
          "id": "YOUR_MISTRAL_CREDENTIAL_ID",
          "name": "Mistral Cloud account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  \n  // Pull original company data from Node 4\n  const company = $('Code in JavaScript').all()[i].json;\n  \n  // Parse AI JSON output\n  let raw = item.json.output;\n  raw = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n  const ai = JSON.parse(raw);\n  \n  results.push({\n    json: {\n      company_name: company.company_name || \"\",\n      city: company.city || \"\",\n      address: company.address || \"\",\n      phone: company.phone || \"\",\n      website: company.website || \"\",\n      category: company.category || \"\",\n      rating: company.rating || \"\",\n      reviews_count: company.reviews_count || \"\",\n      fit_score: ai.fit_score || \"\",\n      fit_reason: ai.fit_reason || \"\",\n      outreach_message: ai.outreach_message || \"\",\n      status: \"New\"\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
